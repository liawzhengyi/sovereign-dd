# sovereign-dd configuration. Copy to .env and fill in. .env is gitignored.
# In CI these are GitHub Actions secrets (see .github/workflows/*.yml).

# ── LLM & data APIs ──────────────────────────────────────────────
GEMINI_API_KEYS=key1,key2              # comma-separated for free-tier rotation
FINNHUB_API_KEY=your_key               # fundamentals / quotes / filings
FMP_API_KEY=your_key                   # financial multiples
FRED_API_KEY=your_key                  # macro indicators
ALPHA_VANTAGE_API_KEYS=key1,key2       # historical prices (optional)

# ── Sync to Sovereign Eye (KV + upload endpoint) ─────────────────
SOVEREIGN_EYE_URL=https://sovereign-eye.pages.dev   # production apex
DD_UPLOAD_SECRET=your_shared_secret    # must match Cloudflare Pages env

# ── Supabase (optional; history + cache disabled if empty) ───────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=your_service_role_key     # service role — keep secret, rotate (see SECRETS.md)

# ── Telegram notifications (optional; disabled if empty) ─────────
TELEGRAM_BOT_TOKEN=your_token
TELEGRAM_CHAT_ID=your_chat_id
TELEGRAM_TOPIC_TRADE_ALERTS=123
TELEGRAM_TOPIC_DEEP_DIVES=124
TELEGRAM_TOPIC_SCAN_RESULTS=125

# ── Portfolio & strategy ─────────────────────────────────────────
PORTFOLIO_TICKERS=AMZN,MSFT,NVDA       # comma-separated

# ── Scout / Gems tuning (all optional; defaults shown) ───────────
SCOUT_DEBATE_COUNT=24
SCOUT_COOLDOWN_HOURS=48
SCOUT_NOTIFY_COOLDOWN_HOURS=168
SCOUT_MAX_LOOPS=3
GEMS_DEBATE_COUNT=6
GEMS_COOLDOWN_HOURS=72
